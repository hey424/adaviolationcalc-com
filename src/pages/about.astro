---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About adaviolationcalc.com';
const description = 'About the team behind adaviolationcalc.com. Free ADA violation damages calculators and plain-English guides reviewed by the editorial team at The Click Lab.';
---
<BaseLayout title={title} description={description}>
  <h1>About adaviolationcalc.com</h1>
  <p>adaviolationcalc.com is a free disability rights resource maintained by The Click Lab. Our calculator and guides help people understand ADA violation damages and what factors affect potential outcomes.</p>
  <h2>What we do</h2>
  <p>We translate complex legal and financial concepts into plain-English calculators and explanations. Every page is reviewed by our <a href="/editorial">editorial team</a> with citations to applicable statutes and case law.</p>
  <h2>What we don&rsquo;t do</h2>
  <p>We don&rsquo;t provide legal or professional advice. Outcomes depend heavily on jurisdiction, facts, and individual circumstances. For your specific situation, consult a licensed professional.</p>
  <h2>How we make money</h2>
  <p>Display advertising via Google AdSense. We don&rsquo;t sell reader data or accept paid placements. See <a href="/privacy">privacy policy</a>.</p>
  <h2>Contact</h2>
  <p>See our <a href="/contact">contact page</a>.</p>
</BaseLayout>
