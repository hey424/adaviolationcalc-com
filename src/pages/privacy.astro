---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy | adaviolationcalc.com';
const description = 'Privacy policy for adaviolationcalc.com — data collection, cookies, Google AdSense, and Google Analytics practices.';
---
<BaseLayout title={title} description={description}>
  <h1>Privacy Policy</h1>
  <p><strong>Effective date:</strong> January 1, 2026</p>

  <h2>Information we collect</h2>
  <p>adaviolationcalc.com does not collect personal information directly. We do not require account creation, registration, or submission of personal data to use the calculator or read the guides. Calculator inputs are processed entirely in your browser and are not transmitted to our servers.</p>

  <h2>Cookies and advertising</h2>
  <p>We serve display advertising through Google AdSense (publisher ID: ca-pub-6434377544325972). Google AdSense uses cookies to serve relevant advertisements based on your prior visits to websites. You may opt out of personalized advertising by visiting <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ad Settings</a>.</p>

  <h2>Analytics</h2>
  <p>We use Google Analytics (GA4) to understand aggregate traffic patterns — which pages are visited, how long visitors stay, and how they navigate the site. Google Analytics collects data per Google&rsquo;s privacy policy, including anonymized IP addresses and browser/device information. We do not use this data to identify individual visitors. You can opt out using the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google Analytics Opt-out Browser Add-on</a>.</p>

  <h2>Third-party services</h2>
  <p>This site uses Google AdSense and Google Analytics, both subject to <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google&rsquo;s Privacy Policy</a>. We do not use any other third-party data collection services, sell reader data, or share personal information with advertisers or other third parties.</p>

  <h2>Your choices</h2>
  <p>You can control cookie preferences through your browser settings. Refusing advertising cookies will not affect your ability to use the calculator or read our content.</p>

  <h2>Contact</h2>
  <p>Questions about this privacy policy? Email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>
</BaseLayout>
