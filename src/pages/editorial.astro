---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Editorial Team';
const description = 'The editorial team behind The Click Lab's legal and financial calculator sites.';
---
<BaseLayout title={title} description={description}>
  <h1>Editorial Team</h1>
  <p>All content on this site is written and reviewed by The Click Lab&rsquo;s editorial team before publication. Our team includes contributors with backgrounds in law, economics, and technical writing.</p>
  <h2>Our editorial standards</h2>
  <ul>
    <li>Every factual claim is sourced to a primary authority (statute, regulation, published case, or government data).</li>
    <li>Calculator formulas are documented on the <a href="/methodology">methodology page</a> so readers can verify the math.</li>
    <li>Pages are reviewed and updated when laws or regulations change.</li>
    <li>We do not accept sponsored content or paid placements.</li>
  </ul>
  <h2>Corrections</h2>
  <p>Found an error? Use our <a href="/contact">contact form</a> and we&rsquo;ll review and correct promptly.</p>
</BaseLayout>
